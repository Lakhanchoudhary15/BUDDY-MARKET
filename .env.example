# Buddy Market Environment Variables
# Copy this file to .env and fill in your values

# Database Type: 'mongodb' or 'sqlite' (default is sqlite)
DB_TYPE=mongodb

# MongoDB Connection String (if DB_TYPE=mongodb)
# Get this from MongoDB Atlas after creating a cluster
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/buddymarket?retryWrites=true&w=majority

# Server Port (default is 80)
PORT=80

# Admin Credentials (default: admin / VS1234)
# It's recommended to change these for security

